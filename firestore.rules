// ================================================================
//  DesiDirect — Firestore Security Rules
//  IMPORTANT: Publish these in Firebase Console > Firestore > Rules
//  Without these rules, customers CANNOT see producer products!
// ================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Products ─────────────────────────────────────────────────
    // Anyone (including logged-out customers) can read products.
    // Only logged-in users (producers) can create/update products.
    match /products/{productId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.producerId;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.producerId;
    }

    // ── Orders ───────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }

    // ── Users (profile data) ─────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Artisans (public profiles) ───────────────────────────────
    match /artisans/{artisanId} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == artisanId;
    }

  }
}
